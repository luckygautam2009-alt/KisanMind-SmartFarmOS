{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with language preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "preferredLanguage": { "type": "string", "enum": ["en", "hi"] },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "preferredLanguage"]
    },
    "Farm": {
      "title": "Farm",
      "description": "Farm details for personalized insights.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "string" },
        "cropType": { "type": "string" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" }, "address": { "type": "string" } } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "cropType"]
    },
    "Scan": {
      "title": "Crop Scan",
      "description": "Record of a crop disease scan result.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "farmId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "diseaseName": { "type": "string" },
        "confidence": { "type": "number" },
        "recommendation": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "imageUrl", "diseaseName"]
    },
    "Alert": {
      "title": "Smart Alert",
      "description": "Proactive alert generated by AI agents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "agentType": { "type": "string", "enum": ["Weather", "Market", "Planning", "System"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["ownerId", "agentType", "title", "message"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "farms/{farmId}": {
      "schema": "Farm",
      "description": "Collection of user farms."
    },
    "scans/{scanId}": {
      "schema": "Scan",
      "description": "Collection of crop scan history."
    },
    "alerts/{alertId}": {
      "schema": "Alert",
      "description": "System-generated smart alerts."
    }
  }
}
